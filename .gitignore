```gitignore
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/

# Jupyter Notebook
.ipynb_checkpoints/

# Build files
build/
dist/
*.egg-info/

# Test and coverage
.pytest_cache/
.coverage
htmlcov/

# Environment variables
.env

# Log files
*.log

# Temporary files
*.tmp
*.swp
*~

# Operating system files
.DS_Store
Thumbs.db
```

